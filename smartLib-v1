CREATE PROCEDURE public.confirm_nfc_payment(IN p_order_id integer, IN p_payment_method character varying, IN p_librarian_id integer)
    LANGUAGE plpgsql
    AS $$
DECLARE
    v_user_id INT;
    v_card_price DECIMAL;
    v_invoice_code VARCHAR;
BEGIN
    SELECT user_id, card_price INTO v_user_id, v_card_price 
    FROM nfc_orders WHERE order_id = p_order_id AND payment_status = 'pending';

    IF v_user_id IS NULL THEN
        RAISE EXCEPTION 'Đơn hàng không tồn tại hoặc đã được thanh toán!';
    END IF;

    UPDATE nfc_orders SET payment_status = 'paid' WHERE order_id = p_order_id;

    v_invoice_code := 'INV-' || TO_CHAR(CURRENT_DATE, 'YYYYMMDD') || '-' || p_order_id;

    INSERT INTO invoices (invoice_code, order_id, user_id, total_amount, payment_method, confirmed_by_librarian_id)
    VALUES (v_invoice_code, p_order_id, v_user_id, v_card_price, p_payment_method, p_librarian_id);
END;
$$;


