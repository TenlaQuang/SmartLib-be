--

CREATE PROCEDURE public.process_return(IN p_transaction_id integer)
    LANGUAGE plpgsql
    AS $$
DECLARE
    v_book_id INT;
    v_borrow_date TIMESTAMP;
    v_due_date TIMESTAMP;
    v_return_date TIMESTAMP := CURRENT_TIMESTAMP;
    v_market_price DECIMAL;
    v_rental_rate DECIMAL;
    v_fine_rate DECIMAL;
    v_deposit DECIMAL;
    v_days_rented INT;
    v_days_overdue INT;
    v_rental_fee DECIMAL;
    v_fine_fee DECIMAL;
BEGIN
    SELECT t.book_id, t.borrow_date, t.due_date, t.deposit_amount, 
           b.market_price, b.rental_rate_percent, b.fine_rate_percent
    INTO v_book_id, v_borrow_date, v_due_date, v_deposit, 
         v_market_price, v_rental_rate, v_fine_rate
    FROM transactions t
    JOIN books b ON t.book_id = b.book_id
    WHERE t.transaction_id = p_transaction_id AND t.status = 'ongoing';

    IF v_book_id IS NULL THEN
        RAISE EXCEPTION 'Giao dịch không hợp lệ hoặc đã hoàn tất!';
    END IF;

    -- Tính số ngày mượn thực tế và số ngày trễ (Làm tròn lên)
    v_days_rented := CEIL(EXTRACT(EPOCH FROM (v_return_date - v_borrow_date)) / 86400);
    v_days_overdue := GREATEST(0, CEIL(EXTRACT(EPOCH FROM (v_return_date - v_due_date)) / 86400));
    IF v_days_rented = 0 THEN v_days_rented := 1; END IF; -- Trả trong ngày tính là 1 ngày

    -- Tính chi phí dựa trên % giá trị sách
    v_rental_fee := v_days_rented * (v_market_price * v_rental_rate / 100);
    v_fine_fee := v_days_overdue * (v_market_price * v_fine_rate / 100);

    -- Cập nhật giao dịch
    UPDATE transactions 
    SET return_date = v_return_date,
        total_fee = v_rental_fee + v_fine_fee,
        refund_amount = GREATEST(0, v_deposit - (v_rental_fee + v_fine_fee)),
        status = 'completed'
    WHERE transaction_id = p_transaction_id;

    -- Giải phóng sách về trạng thái sẵn sàng
    UPDATE books SET status = 'available' WHERE book_id = v_book_id;
END;
$$;


