CREATE FUNCTION public.set_deposit_and_status() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
    SELECT deposit_required INTO NEW.deposit_amount 
    FROM books WHERE book_id = NEW.book_id;
    
    UPDATE books SET status = 'borrowed' WHERE book_id = NEW.book_id;
    RETURN NEW;
END;
$$;


